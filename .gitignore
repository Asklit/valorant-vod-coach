# Raw datasets are local-only. Keep only directory placeholders in git.
data/raw/**
!data/raw/
!data/raw/.gitkeep
!data/raw/youtube/
!data/raw/youtube/.gitkeep

# Generated pipeline artifacts.
data/processed/
data/cache/

# Local build outputs and tool caches.
.cache/
bin/
node_modules/
web/app/node_modules/
web/app/.vite/
web/app/dist/
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Large media files should never be committed.
*.mp4
*.mkv
*.webm
*.mov
*.avi
*.flv

# Temporary download files.
*.part
*.ytdl
*.tmp

# Local config, logs, and coverage.
.env
.env.*
*.log
*.out
coverage.*
*.tsbuildinfo

.DS_Store
